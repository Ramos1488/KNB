function loadConversations() {
    const messages = KNB_DB.getMessages();
    const users = KNB_DB.getUsers();
    
    // Получаем все уникальные диалоги
    const conversations = {};
    
    messages.forEach(message => {
        if (message.senderId === currentUser.id || message.receiverId === currentUser.id) {
            const otherUserId = message.senderId === currentUser.id ? message.receiverId : message.senderId;
            if (!conversations[otherUserId]) {
                conversations[otherUserId] = {
                    userId: otherUserId,
                    lastMessage: message,
                    unread: message.receiverId === currentUser.id && !message.read,
                    count: 1
                };
            } else {
                if (new Date(message.timestamp) > new Date(conversations[otherUserId].lastMessage.timestamp)) {
                    conversations[otherUserId].lastMessage = message;
                }
                if (message.receiverId === currentUser.id && !message.read) {
                    conversations[otherUserId].unread = true;
                }
                conversations[otherUserId].count++;
            }
        }
    });
    
    const conversationsList = document.getElementById('conversationsList');
    const conversationArray = Object.values(conversations);
    
    if (conversationArray.length === 0) {
        conversationsList.innerHTML = `
            <div style="padding: 40px 20px; text-align: center; color: var(--text-secondary);">
                <i class="fas fa-comment-slash" style="font-size: 40px; margin-bottom: 15px;"></i>
                <p>У вас пока нет сообщений</p>
            </div>
        `;
        return;
    }
    
    // Сортируем по времени последнего сообщения
    conversationArray.sort((a, b) => 
        new Date(b.lastMessage.timestamp) - new Date(a.lastMessage.timestamp)
    );
    
    conversationsList.innerHTML = conversationArray.map(conv => {
        const user = users.find(u => u.id === conv.userId);
        if (!user) return '';
        
        conversationUsers[conv.userId] = user;
        
        const lastMessage = conv.lastMessage.content.length > 30 ? 
            conv.lastMessage.content.substring(0, 30) + '...' : conv.lastMessage.content;
        
        return `
            <div class="conversation-item ${currentConversationId === conv.userId ? 'active' : ''}" 
                 onclick="openConversation(${conv.userId})">
                <div class="conversation-avatar" style="background-color: ${user.avatarColor}">
                    ${user.avatarImage ? 
                        `<img src="${user.avatarImage}" alt="${user.name}" style="width: 100%; height: 100%; border-radius: 50%;">` : 
                        user.name.charAt(0).toUpperCase()}
                </div>
                <div class="conversation-info">
                    <div class="conversation-name">
                        ${user.name}
                        ${user.verified ? '<i class="fas fa-check-circle verified-badge" style="font-size: 12px;"></i>' : ''}
                        ${conv.unread ? '<span style="background: var(--primary-color); color: white; font-size: 10px; padding: 2px 6px; border-radius: 10px;">новое</span>' : ''}
                    </div>
                    <div class="conversation-last-message">
                        ${conv.lastMessage.senderId === currentUser.id ? 'Вы: ' : ''}${lastMessage}
                    </div>
                </div>
                <div class="conversation-time">
                    ${formatTime(conv.lastMessage.timestamp)}
                </div>
            </div>
        `;
    }).join('');
}

function openConversation(userId) {
    currentConversationId = userId;
    const user = conversationUsers[userId];
    
    if (!user) return;
    
    document.getElementById('noConversation').style.display = 'none';
    document.getElementById('activeConversation').style.display = 'flex';
    document.getElementById('activeConversation').style.flexDirection = 'column';
    
    // Заголовок диалога
    document.getElementById('conversationHeader').innerHTML = `
        <div class="conversation-avatar" style="width: 40px; height: 40px; background-color: ${user.avatarColor}">
            ${user.avatarImage ? 
                `<img src="${user.avatarImage}" alt="${user.name}" style="width: 100%; height: 100%; border-radius: 50%;">` : 
                user.name.charAt(0).toUpperCase()}
        </div>
        <div>
            <div style="font-weight: bold; display: flex; align-items: center; gap: 5px;">
                ${user.name}
                ${user.verified ? '<i class="fas fa-check-circle verified-badge"></i>' : ''}
            </div>
            <div style="font-size: 14px; color: var(--text-secondary);">
                ${user.online ? '<span style="color: var(--success);">● онлайн</span>' : 'был(а) недавно'}
            </div>
        </div>
    `;
    
    loadMessages(userId);
    markMessagesAsRead(userId);
    loadConversations(); // Обновляем список, чтобы убрать метку "новое"
}

function loadMessages(userId) {
    const messages = KNB_DB.getMessages();
    const messagesList = document.getElementById('messagesList');
    
    const conversationMessages = messages.filter(msg => 
        (msg.senderId === currentUser.id && msg.receiverId === userId) ||
        (msg.senderId === userId && msg.receiverId === currentUser.id)
    ).sort((a, b) => new Date(a.timestamp) - new Date(b.timestamp));
    
    if (conversationMessages.length === 0) {
        messagesList.innerHTML = `
            <div style="text-align: center; color: var(--text-secondary); margin-top: 40px;">
                <i class="fas fa-comment" style="font-size: 40px; margin-bottom: 15px;"></i>
                <p>Начните общение с этим пользователем</p>
            </div>
        `;
        return;
    }
    
    messagesList.innerHTML = conversationMessages.map(msg => {
        const isSent = msg.senderId === currentUser.id;
        return `
            <div class="message ${isSent ? 'sent' : 'received'}">
                <div class="message-content">
                    ${msg.content}
                    ${msg.attachment ? `<div style="margin-top: 10px;"><i class="fas fa-paperclip"></i> Вложение</div>` : ''}
                </div>
                <div class="message-time">
                    ${formatTime(msg.timestamp)}
                    ${isSent && msg.read ? ' <i class="fas fa-check-double" style="color: var(--verified-color);"></i>' : ''}
                </div>
            </div>
        `;
    }).join('');
    
    // Прокручиваем вниз
    messagesList.scrollTop = messagesList.scrollHeight;
}

function sendMessage() {
    const input = document.getElementById('messageInput');
    const message = input.value.trim();
    
    if (!message || !currentConversationId) return;
    
    const newMessage = {
        senderId: currentUser.id,
        receiverId: currentConversationId,
        content: message,
        timestamp: new Date().toISOString(),
        read: false
    };
    
    KNB_DB.addMessage(newMessage);
    input.value = '';
    loadMessages(currentConversationId);
    loadConversations();
    
    // Отправляем уведомление (в реальном приложении здесь был бы WebSocket)
    const receiver = KNB_DB.getUserById(currentConversationId);
    if (receiver && receiver.notifications) {
        receiver.notifications.push({
            type: 'message',
            fromUserId: currentUser.id,
            fromUserName: currentUser.name,
            message: `Новое сообщение от ${currentUser.name}`,
            timestamp: new Date().toISOString(),
            read: false
        });
        KNB_DB.updateUser(receiver);
    }
}

function markMessagesAsRead(userId) {
    const messages = KNB_DB.getMessages();
    let updated = false;
    
    messages.forEach(msg => {
        if (msg.receiverId === currentUser.id && msg.senderId === userId && !msg.read) {
            msg.read = true;
            updated = true;
        }
    });
    
    if (updated) {
        localStorage.setItem('knb_messages', JSON.stringify(messages));
    }
}

function startNewConversation() {
