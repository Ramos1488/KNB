        function getMediaHTML(mediaData, mediaType) {
            if (!mediaData) return '';
            
            if (mediaType === 'image') {
                return `<img src="${mediaData}" alt="Пост" class="post-image" onclick="openFullscreenMedia('${mediaData}', 'image')">`;
            } else if (mediaType === 'video') {
                return `<video controls class="post-video" onclick="openFullscreenMedia('${mediaData}', 'video')">
                    <source src="${mediaData}" type="video/mp4">
                    Ваш браузер не поддерживает видео.
                </video>`;
            } else if (mediaType === 'audio') {
                return `<audio controls class="post-audio">
                    <source src="${mediaData}" type="audio/mpeg">
                    Ваш браузер не поддерживает аудио.
                </audio>`;
            }
            return '';
        }

        function formatTime(timestamp) {
            const date = new Date(timestamp);
            const now = new Date();
            const diff = now - date;
            
            if (diff < 60000) return 'только что';
            if (diff < 3600000) return `${Math.floor(diff / 60000)} мин назад`;
            if (diff < 86400000) return `${Math.floor(diff / 3600000)} ч назад`;
            return `${date.getDate().toString().padStart(2, '0')}.${(date.getMonth() + 1).toString().padStart(2, '0')}.${date.getFullYear()}`;
        }

