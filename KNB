        // Друзья
        function sendFriendRequest(userId) {
            const user = KNB_DB.getUserById(userId);
            if (!user) return;
            
            if (!user.friendRequests) user.friendRequests = [];
            
            if (user.friendRequests.includes(currentUser.id)) {
                alert('Вы уже отправили заявку этому пользователю');
                return;
            }
            
            user.friendRequests.push(currentUser.id);
            KNB_DB.updateUser(user);
            
            alert('Заявка в друзья отправлена');
            showProfile(userId);
            loadFriendRequests();
        }

        function acceptFriendRequest(userId) {
            const sender = KNB_DB.getUserById(userId);
            if (!sender) return;
            
            if (currentUser.friendRequests) {
                const requestIndex = currentUser.friendRequests.indexOf(userId);
                if (requestIndex !== -1) {
                    currentUser.friendRequests.splice(requestIndex, 1);
                }
            }
            
            if (!currentUser.friends) currentUser.friends = [];
            if (!sender.friends) sender.friends = [];
            
            if (!currentUser.friends.includes(userId)) {
                currentUser.friends.push(userId);
            }
            
            if (!sender.friends.includes(currentUser.id)) {
                sender.friends.push(currentUser.id);
            }
            
            KNB_DB.updateUser(currentUser);
            KNB_DB.updateUser(sender);
            
            alert(`Теперь вы дружите с ${sender.name}`);
            loadFriendRequests();
        }

        function declineFriendRequest(userId) {
            const sender = KNB_DB.getUserById(userId);
            if (!sender) return;
            
            if (currentUser.friendRequests) {
                const requestIndex = currentUser.friendRequests.indexOf(userId);
                if (requestIndex !== -1) {
                    currentUser.friendRequests.splice(requestIndex, 1);
                }
            }
            
            KNB_DB.updateUser(currentUser);
            
            alert(`Заявка от ${sender.name} отклонена`);
            loadFriendRequests();
        }

        function removeFriend(userId) {
            const user = KNB_DB.getUserById(userId);
            if (!user) return;
            
            if (currentUser.friends) {
                const friendIndex = currentUser.friends.indexOf(userId);
                if (friendIndex !== -1) {
                    currentUser.friends.splice(friendIndex, 1);
