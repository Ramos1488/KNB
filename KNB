        function register() {
            const email = document.getElementById('registerEmail').value;
            const password = document.getElementById('registerPassword').value;
            const confirmPassword = document.getElementById('registerConfirmPassword').value;
            
            if (!email || !password || !confirmPassword) {
                alert('Заполните все поля');
                return;
            }
            
            if (password !== confirmPassword) {
                alert('Пароли не совпадают');
                return;
            }
            
            const existingUser = KNB_DB.getUserByEmail(email);
            if (existingUser) {
                alert('Пользователь с таким email уже существует');
                return;
            }
            
            emailVerificationCode = Math.floor(100000 + Math.random() * 900000).toString();
            alert(`Код подтверждения отправлен на ${email}\nКод: ${emailVerificationCode}`);
            
            currentUser = {
                tempEmail: email,
                tempPassword: password
            };
            
            showVerifyEmailForm();
        }

        function verifyEmail() {
            const code = document.getElementById('verificationCode').value;
            
            if (code !== emailVerificationCode) {
                alert('Неверный код подтверждения');
                return;
            }
            
            showSetupProfileForm();
        }

        function completeProfileSetup() {
            const name = document.getElementById('profileName').value;
            const username = document.getElementById('profileUsername').value;
            
            if (!name || !username) {
                alert('Заполните обязательные поля');
                return;
            }
            
            if (!username.startsWith('@')) {
                alert('Юзернейм должен начинаться с @');
                return;
            }
            
            const users = KNB_DB.getUsers();
            const newUserId = users.length > 0 ? Math.max(...users.map(u => u.id)) + 1 : 1;
            
            const newUser = {
                id: newUserId,
                email: currentUser.tempEmail,
                password: currentUser.tempPassword,
                username: username,
                name: name,
                avatarColor: KNB_DB.getColorFromName(name),
                bannerColor: KNB_DB.getColorFromName(name + "banner"),
                bio: 'Привет! Я новый пользователь KNB',
                verified: false,
                isAdmin: false,
                friends: [],
                friendRequests: [],
                posts: [],
                notifications: [],
                joined: new Date().toISOString(),
                theme: 'dark'
            };
            
            users.push(newUser);
            localStorage.setItem('knb_users', JSON.stringify(users));
            
            currentUser = newUser;
            localStorage.setItem('knb_current_user', JSON.stringify(currentUser));
            showMainApp();
        }

        function login() {
            const email = document.getElementById('loginEmail').value;
            const password = document.getElementById('loginPassword').value;
            
            const user = KNB_DB.getUserByEmail(email);
            
            if (user && user.password === password) {
