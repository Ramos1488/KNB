// Расширенная система верификации
let selectedVerificationType = 'blue';
let verificationDocumentFile = null;
let verificationDocumentUrl = null;

function showVerificationModal() {
    if (currentUser.verified) {
        alert('Ваш аккаунт уже верифицирован!');
        return;
    }
    
    const existingRequest = KNB_DB.getVerificationRequests().find(
        req => req.userId === currentUser.id && req.status === 'pending'
    );
    
    if (existingRequest) {
        document.getElementById('verificationModal').classList.add('active');
        document.getElementById('verificationForm').style.display = 'none';
        
        const statusDiv = document.getElementById('verificationStatus');
        statusDiv.style.display = 'block';
        statusDiv.innerHTML = `
            <h3>Заявка на рассмотрении</h3>
            <p>Ваша заявка на верификацию находится на рассмотрении.</p>
            <p><strong>Дата подачи:</strong> ${formatTime(existingRequest.submitted)}</p>
            <p><strong>Тип:</strong> ${existingRequest.type || 'стандартная'}</p>
            <div style="background-color: rgba(250, 166, 26, 0.1); padding: 15px; border-radius: 8px; margin-top: 15px;">
                <i class="fas fa-clock" style="color: var(--warning); margin-right: 10px;"></i>
                Обычно рассмотрение занимает 3-7 рабочих дней
            </div>
            <button class="btn btn-danger" onclick="cancelVerificationRequest()" style="margin-top: 20px;">
                Отозвать заявку
            </button>
        `;
        return;
    }
    
    document.getElementById('verificationTypeModal').classList.add('active');
}

function closeVerificationTypeModal() {
    document.getElementById('verificationTypeModal').classList.remove('active');
}

function selectVerificationType(type) {
    selectedVerificationType = type;
    
    document.querySelectorAll('.verification-type').forEach(el => {
        el.classList.remove('selected');
    });
    
    document.querySelector(`.verification-type.${type}`).classList.add('selected');
}

function proceedToVerificationForm() {
    closeVerificationTypeModal();
    document.getElementById('verificationModal').classList.add('active');
    
    const form = document.getElementById('verificationForm');
    form.style.display = 'block';
    form.innerHTML = `
        <h3>Верификация: ${getVerificationTypeName(selectedVerificationType)}</h3>
        ${selectedVerificationType !== 'blue' ? `
            <div style="background-color: rgba(255, 215, 0, 0.1); padding: 15px; border-radius: 8px; margin-bottom: 20px;">
                <i class="fas fa-gem" style="color: gold; margin-right: 10px;"></i>
                <strong>${selectedVerificationType === 'gold' ? 'Золотая' : 'Серебряная'} верификация:</strong>
                Платный статус с дополнительными возможностями
            </div>
        ` : ''}
        
        <div class="form-group">
            <label>Ваше настоящее имя</label>
            <input type="text" id="verificationRealName" class="form-control" placeholder="Как в документах" value="${currentUser.name}">
        </div>
        
        <div class="form-group">
            <label>Номер телефона</label>
            <input type="tel" id="verificationPhone" class="form-control" placeholder="+7 (XXX) XXX-XX-XX">
        </div>
        
        <div class="form-group">
            <label>Загрузите документ, удостоверяющий личность</label>
            <div class="verification-document-upload" onclick="document.getElementById('verificationDocumentFile').click()">
                <i class="fas fa-upload" style="font-size: 40px; margin-bottom: 15px; color: var(--text-secondary);"></i>
                <p>Нажмите для загрузки документа</p>
                <p style="font-size: 12px; color: var(--text-secondary);">Поддерживаемые форматы: JPG, PNG, PDF (макс. 5MB)</p>
            </div>
            <input type="file" id="verificationDocumentFile" class="file-input" 
                   accept="image/*,.pdf" onchange="previewVerificationDocument(event)">
            <div id="verificationDocumentPreview" class="verification-preview" style="display: none;"></div>
        </div>
        
        <div class="form-group">
            <label>Дополнительная информация</label>
            <textarea id="verificationReason" class="form-control" rows="3" 
                      placeholder="Расскажите о себе, своих достижениях, причинах запроса верификации"></textarea>
        </div>
        
        <div class="form-group">
            <label>Ссылки для подтверждения (по одной на строку)</label>
            <textarea id="verificationLinks" class="form-control" rows="2" 
                      placeholder="https://example.com/profile"></textarea>
        </div>
        
        ${selectedVerificationType !== 'blue' ? `
            <div class="form-group">
                <label>Способ оплаты</label>
                <select id="paymentMethod" class="form-control">
                    <option value="card">Банковская карта</option>
                    <option value="qiwi">QIWI</option>
                    <option value="yoomoney">ЮMoney</option>
                </select>
            </div>
        ` : ''}
        
        <button class="btn btn-success btn-block" onclick="submitVerificationRequest()">
            ${selectedVerificationType === 'blue' ? 'Отправить заявку' : 'Перейти к оплате'}
        </button>
    `;
}

function getVerificationTypeName(type) {
    const names = {
        'blue': 'Синяя верификация',
        'silver': 'Серебряная верификация',
        'gold': 'Золотая верификация'
    };
    return names[type] || 'Верификация';
}

function previewVerificationDocument(event) {
    const file = event.target.files[0];
    if (!file) return;
    
    if (file.size > 5 * 1024 * 1024) {
        alert('Файл слишком большой. Максимальный размер: 5MB');
        event.target.value = '';
        return;
    }
    
    verificationDocumentFile = file;
    
    if (verificationDocumentUrl) {
        URL.revokeObjectURL(verificationDocumentUrl);
    }
    
    verificationDocumentUrl = URL.createObjectURL(file);
    const preview = document.getElementById('verificationDocumentPreview');
    preview.style.display = 'block';
    
    if (file.type.startsWith('image/')) {
        preview.innerHTML = `<img src="${verificationDocumentUrl}" alt="Предпросмотр документа">`;
    } else if (file.type === 'application/pdf') {
        preview.innerHTML = `
            <div style="padding: 20px; background-color: var(--darker-bg); border-radius: 8px; text-align: center;">
                <i class="fas fa-file-pdf" style="font-size: 40px; color: #e74c3c; margin-bottom: 10px;"></i>
                <div>${file.name}</div>
                <div style="font-size: 12px; color: var(--text-secondary); margin-top: 5px;">
                    PDF документ
                </div>
            </div>
        `;
    }
}

function submitVerificationRequest() {
    const realName = document.getElementById('verificationRealName').value;
    const phone = document.getElementById('verificationPhone').value;
    const reason = document.getElementById('verificationReason').value;
    const links = document.getElementById('verificationLinks').value;
    
    if (!realName || !phone || !verificationDocumentFile) {
        alert('Заполните обязательные поля и загрузите документ');
        return;
    }
    
    // В реальном приложении здесь была бы оплата
    if (selectedVerificationType !== 'blue') {
        const paymentMethod = document.getElementById('paymentMethod').value;
        alert(`В реальном приложении здесь был бы переход к оплате ${getVerificationTypeName(selectedVerificationType)} через ${paymentMethod}`);
        // Для демо просто создаем заявку
    }
    
    const reader = new FileReader();
    reader.onloadend = function() {
        const verificationRequest = {
            userId: currentUser.id,
            type: selectedVerificationType,
            realName: realName,
            phone: phone,
            document: reader.result,
            documentType: verificationDocumentFile.type,
            reason: reason,
            links: links,
            status: 'pending',
            submitted: new Date().toISOString()
        };
        
        KNB_DB.addVerificationRequest(verificationRequest);
        
        // Создаем уведомление для админов
        const users = KNB_DB.getUsers();
        users.forEach(user => {
            if (user.isAdmin) {
                if (!user.notifications) user.notifications = [];
                user.notifications.push({
                    type: 'verification',
                    fromUserId: currentUser.id,
                    fromUserName: currentUser.name,
                    message: `Новая заявка на ${getVerificationTypeName(selectedVerificationType)}`,
                    timestamp: new Date().toISOString(),
                    read: false
                });
                KNB_DB.updateUser(user);
            }
        });
        
        alert('Заявка на верификацию отправлена! Мы рассмотрим ее в ближайшее время.');
        closeVerificationModal();
        showVerificationPanel();
        
        if (verificationDocumentUrl) {
            URL.revokeObjectURL(verificationDocumentUrl);
            verificationDocumentUrl = null;
        }
    };
    
    reader.readAsDataURL(verificationDocumentFile);
}

function cancelVerificationRequest() {
    if (!confirm('Вы уверены, что хотите отозвать заявку на верификацию?')) return;
    
    const requests = KNB_DB.getVerificationRequests();
    const index = requests.findIndex(req => 
        req.userId === currentUser.id && req.status === 'pending'
    );
    
    if (index !== -1) {
        requests.splice(index, 1);
        localStorage.setItem('knb_verification_requests', JSON.stringify(requests));
        alert('Заявка отозвана');
        closeVerificationModal();
        showVerificationPanel();
    }
}

// Обновляем функцию approveVerification для отправки уведомлений
function approveVerification(userId, level) {
    const user = KNB_DB.getUserById(userId);
    if (!user) return;
    
    user.verified = true;
    user.verificationLevel = level;
    user.verificationDate = new Date().toISOString();
    
    // Добавляем уведомление пользователю
    if (!user.notifications) user.notifications = [];
    user.notifications.push({
        type: 'verification_approved',
        message: `Поздравляем! Ваш аккаунт получил ${level === 'gold' ? 'золотую' : level === 'silver' ? 'серебряную' : 'синюю'} верификацию`,
        timestamp: new Date().toISOString(),
        read: false
    });
    
    KNB_DB.updateUser(user);
    
    const requests = KNB_DB.getVerificationRequests();
    const request = requests.find(r => r.userId === userId && r.status === 'pending');
    if (request) {
        request.status = 'approved';
        request.approvedBy = currentUser.id;
        request.approvedAt = new Date().toISOString();
        localStorage.setItem('knb_verification_requests', JSON.stringify(requests));
    }
    
    alert(`Пользователь ${user.name} верифицирован`);
    showAdminPanel();
}

// Обновляем функцию rejectVerification для отправки уведомлений
function rejectVerification(userId) {
    const user = KNB_DB.getUserById(userId);
    if (!user) return;
    
    // Добавляем уведомление пользователю
    if (!user.notifications) user.notifications = [];
    user.notifications.push({
        type: 'verification_rejected',
        message: 'Ваша заявка на верификацию отклонена. Вы можете подать новую заявку через 30 дней.',
        timestamp: new Date().toISOString(),
        read: false
    });
    
    KNB_DB.updateUser(user);
    
    const requests = KNB_DB.getVerificationRequests();
    const request = requests.find(r => r.userId === userId && r.status === 'pending');
    if (request) {
        request.status = 'rejected';
        request.rejectedBy = currentUser.id;
        request.rejectedAt = new Date().toISOString();
        localStorage.setItem('knb_verification_requests', JSON.stringify(requests));
    }
    
    alert(`Заявка на верификацию от ${user.name} отклонена`);
    showAdminPanel();
}

