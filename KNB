    // Обрабатываем баннер
    if (bannerFile) {
        const reader = new FileReader();
        reader.onloadend = function() {
            currentUser.bannerImage = reader.result;
            if (!avatarFile) {
                completeProfileUpdate();
            }
        };
        reader.readAsDataURL(bannerFile);
    }
}

