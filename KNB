            getColorFromName: function(name) {
                const colors = ['#7289da', '#43b581', '#faa61a', '#f04747', '#9b59b6', '#3498db', '#2ecc71', '#e74c3c'];
                let hash = 0;
                for (let i = 0; i < name.length; i++) {
                    hash = name.charCodeAt(i) + ((hash << 5) - hash);
                }
                return colors[Math.abs(hash) % colors.length];
            },
            
            getUsers: function() {
                return JSON.parse(localStorage.getItem('knb_users') || '[]');
            },
            
            getUserById: function(id) {
                return this.getUsers().find(user => user.id === id);
            },
            
            getUserByEmail: function(email) {
                return this.getUsers().find(user => user.email === email);
            },
            
            updateUser: function(user) {
                const users = this.getUsers();
                const index = users.findIndex(u => u.id === user.id);
                if (index !== -1) {
                    users[index] = user;
                    localStorage.setItem('knb_users', JSON.stringify(users));
                    return true;
                }
                return false;
            },
            
            getPosts: function() {
                return JSON.parse(localStorage.getItem('knb_posts') || '[]');
            },
            
            addPost: function(post) {
                const posts = this.getPosts();
                post.id = posts.length > 0 ? Math.max(...posts.map(p => p.id)) + 1 : 1;
                posts.unshift(post);
                localStorage.setItem('knb_posts', JSON.stringify(posts));
                return post;
            },
            
            updatePost: function(post) {
                const posts = this.getPosts();
                const index = posts.findIndex(p => p.id === post.id);
                if (index !== -1) {
                    posts[index] = post;
                    localStorage.setItem('knb_posts', JSON.stringify(posts));
                    return true;
                }
                return false;
            },
            
            deletePost: function(postId) {
                const posts = this.getPosts();
                const index = posts.findIndex(p => p.id === postId);
                if (index !== -1) {
                    posts.splice(index, 1);
                    localStorage.setItem('knb_posts', JSON.stringify(posts));
                    return true;
                }
                return false;
            },
            
            getClans: function() {
                return JSON.parse(localStorage.getItem('knb_clans') || '[]');
            },
            
            getMessages: function() {
                return JSON.parse(localStorage.getItem('knb_messages') || '[]');
            },
            
            addMessage: function(message) {
                const messages = this.getMessages();
                message.id = messages.length > 0 ? Math.max(...messages.map(m => m.id)) + 1 : 1;
                messages.push(message);
                localStorage.setItem('knb_messages', JSON.stringify(messages));
                return message;
            },
            
            getVerificationRequests: function() {
                return JSON.parse(localStorage.getItem('knb_verification_requests') || '[]');
            },
            
            addVerificationRequest: function(request) {
                const requests = this.getVerificationRequests();
                request.id = requests.length > 0 ? Math.max(...requests.map(r => r.id)) + 1 : 1;
                request.status = 'pending';
                request.createdAt = new Date().toISOString();
                requests.push(request);
                localStorage.setItem('knb_verification_requests', JSON.stringify(requests));
                return request;
            },
            
            updateVerificationRequest: function(request) {
                const requests = this.getVerificationRequests();
                const index = requests.findIndex(r => r.id === request.id);
                if (index !== -1) {
                    requests[index] = request;
                    localStorage.setItem('knb_verification_requests', JSON.stringify(requests));
                    return true;
                }
                return false;
            }
        };

