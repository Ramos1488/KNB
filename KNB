                name: currentUser.name,
                avatarColor: currentUser.avatarColor,
                content: text,
                media: null,
                mediaType: null,
                likes: [],
                comments: [],
                timestamp: new Date().toISOString()
            };
            
            KNB_DB.addPost(newPost);
            document.getElementById('quickPostText').value = '';
            loadFeed();
        }

        // Функции постов
        function showCreatePostModal() {
            document.getElementById('createPostModal').classList.add('active');
            selectedMediaFile = null;
            mediaPreviewUrl = null;
            document.getElementById('filePreview').style.display = 'none';
            document.getElementById('mediaFile').value = '';
            document.getElementById('postText').value = '';
        }

        function closeCreatePostModal() {
            document.getElementById('createPostModal').classList.remove('active');
            if (mediaPreviewUrl) {
                URL.revokeObjectURL(mediaPreviewUrl);
                mediaPreviewUrl = null;
            }
        }

        function previewMedia(event) {
            const file = event.target.files[0];
            if (!file) return;
            
            if (file.size > 10 * 1024 * 1024) {
                alert('Файл слишком большой. Максимальный размер: 10MB');
                event.target.value = '';
                return;
            }
            
            selectedMediaFile = file;
            
            if (mediaPreviewUrl) {
                URL.revokeObjectURL(mediaPreviewUrl);
            }
            
            mediaPreviewUrl = URL.createObjectURL(file);
            const preview = document.getElementById('filePreview');
            preview.style.display = 'block';
            
            if (file.type.startsWith('image/')) {
                preview.innerHTML = `<img src="${mediaPreviewUrl}" alt="Превью">`;
            } else if (file.type.startsWith('video/')) {
                preview.innerHTML = `<video controls><source src="${mediaPreviewUrl}" type="${file.type}"></video>`;
            } else if (file.type.startsWith('audio/')) {
                preview.innerHTML = `<audio controls><source src="${mediaPreviewUrl}" type="${file.type}"></audio>`;
            }
        }

        function createPost() {
            const text = document.getElementById('postText').value;
            
            if (!text.trim() && !selectedMediaFile) {
                alert('Введите текст или добавьте медиа');
                return;
            }
            
            const progressBar = document.getElementById('progressBar');
            const uploadProgress = document.getElementById('uploadProgress');
            uploadProgress.style.display = 'block';
            progressBar.style.width = '0%';
            
            let progress = 0;
            const progressInterval = setInterval(() => {
                progress += 10;
                progressBar.style.width = progress + '%';
                
                if (progress >= 100) {
                    clearInterval(progressInterval);
                    
                    const reader = new FileReader();
                    
                    reader.onloadend = function() {
                        const mediaData = reader.result;
                        const mediaType = selectedMediaFile.type.startsWith('image/') ? 'image' : 
                                         selectedMediaFile.type.startsWith('video/') ? 'video' : 'audio';
                        
                        const newPost = {
                            userId: currentUser.id,
                            username: currentUser.username,
                            name: currentUser.name,
                            avatarColor: currentUser.avatarColor,
                            content: text,
                            media: mediaData,
                            mediaType: mediaType,
                            likes: [],
                            comments: [],
                            timestamp: new Date().toISOString()
                        };
                        
                        KNB_DB.addPost(newPost);
                        closeCreatePostModal();
                        loadFeed();
                        uploadProgress.style.display = 'none';
                        
                        if (mediaPreviewUrl) {
                            URL.revokeObjectURL(mediaPreviewUrl);
                            mediaPreviewUrl = null;
                        }
                    };
                    
                    if (selectedMediaFile) {
                        reader.readAsDataURL(selectedMediaFile);
                    } else {
                        const newPost = {
                            userId: currentUser.id,
                            username: currentUser.username,
                            name: currentUser.name,
                            avatarColor: currentUser.avatarColor,
                            content: text,
                            media: null,
                            mediaType: null,
                            likes: [],
                            comments: [],
                            timestamp: new Date().toISOString()
                        };
                        
                        KNB_DB.addPost(newPost);
                        closeCreatePostModal();
                        loadFeed();
                        uploadProgress.style.display = 'none';
                    }
                }
            }, 50);
        }

        function deletePost(postId) {
            if (!confirm('Вы уверены, что хотите удалить этот пост?')) return;
            
            const post = KNB_DB.getPosts().find(p => p.id === postId);
            if (!post) return;
            
            if (post.userId !== currentUser.id && !currentUser.isAdmin) {
                alert('Вы не можете удалить этот пост');
                return;
            }
            
            KNB_DB.deletePost(postId);
            loadFeed();
            alert('Пост удален');
        }

        function likePost(postId) {
            const posts = KNB_DB.getPosts();
            const post = posts.find(p => p.id === postId);
            
            if (!post) return;
            
            if (!post.likes) post.likes = [];
            
            const likeIndex = post.likes.indexOf(currentUser.id);
            if (likeIndex === -1) {
                post.likes.push(currentUser.id);
            } else {
                post.likes.splice(likeIndex, 1);
            }
            
            KNB_DB.updatePost(post);
            loadFeed();
        }

        function toggleComments(postId) {
            const commentsSection = document.getElementById(`comments-${postId}`);
            if (commentsSection.style.display === 'none') {
                commentsSection.style.display = 'block';
            } else {
                commentsSection.style.display = 'none';
            }
        }

        function addComment(postId) {
            const commentInput = document.getElementById(`comment-input-${postId}`);
            const commentText = commentInput.value.trim();
            
            if (!commentText) {
                alert('Введите текст комментария');
                return;
            }
            
            const posts = KNB_DB.getPosts();
            const post = posts.find(p => p.id === postId);
            
            if (!post) return;
            
            if (!post.comments) post.comments = [];
            
            const newComment = {
                id: post.comments.length + 1,
                userId: currentUser.id,
                name: currentUser.name,
                content: commentText,
                timestamp: new Date().toISOString()
            };
            
            post.comments.push(newComment);
            KNB_DB.updatePost(post);
            
            commentInput.value = '';
            loadFeed();
        }

