                        </div>
                        <div class="post-user-info">
                            <div class="post-username">
                                ${post.name}
                                ${isVerified ? `<i class="fas fa-check-circle verified-badge" title="Верифицированный аккаунт"></i>` : ''}
                                ${verificationLevel === 'gold' ? '<span class="verification-badge" title="Золотая верификация"><i class="fas fa-crown"></i> Gold</span>' : ''}
