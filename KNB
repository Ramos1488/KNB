    const bio = document.getElementById('editProfileBio').value;
    
    if (!name || !username) {
        alert('Заполните имя и юзернейм');
        return;
    }
    
    if (!username.startsWith('@')) {
        alert('Юзернейм должен начинаться с @');
        return;
    }
    
    // Обновляем данные пользователя
    currentUser.name = name;
    currentUser.username = username;
    currentUser.bio = bio;
    currentUser.bannerColor = selectedBannerColor;
    
    // Обрабатываем аватар
    if (avatarFile) {
        const reader = new FileReader();
        reader.onloadend = function() {
            currentUser.avatarImage = reader.result;
            completeProfileUpdate();
        };
        reader.readAsDataURL(avatarFile);
    } else {
        completeProfileUpdate();
